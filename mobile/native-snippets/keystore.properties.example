# Copy to android/keystore.properties in the generated RN app and fill in real values.
# NEVER commit the filled-in file or the .keystore — add both to .gitignore:
#     android/keystore.properties
#     android/app/*.keystore
#
# Create the upload keystore once (see RELEASE_SIGNING.md), then point these at it.

storeFile=kokonada-upload.keystore
storePassword=CHANGE_ME
keyAlias=kokonada-upload
keyPassword=CHANGE_ME
