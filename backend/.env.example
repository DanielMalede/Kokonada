# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai_music_app

# Redis
REDIS_URL=redis://localhost:6379

# Auth - JWT
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# Encryption (AES-256-GCM) - must be exactly 64 hex chars (32 bytes)
ENCRYPTION_KEY=change_me_to_64_hex_chars_0000000000000000000000000000000000000000

# SSO - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# SSO - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# SSO - Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/auth/facebook/callback

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback

# YouTube Music
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/auth/youtube/callback

# Garmin
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Google Gemini
GEMINI_API_KEY=

# Sentry
SENTRY_DSN=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
