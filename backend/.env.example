# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/kokonada

# Redis
REDIS_URL=redis://localhost:6379

# Auth - JWT
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# Encryption (AES-256-GCM) - must be exactly 64 hex chars (32 bytes)
ENCRYPTION_KEY=change_me_to_64_hex_chars_0000000000000000000000000000000000000000
# Optional: comma-separated previous key(s), tried on decrypt during key rotation.
# To rotate: set ENCRYPTION_KEY to the new key, move the old one here. (audit F8)
ENCRYPTION_KEY_PREVIOUS=

# SSO - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SSO - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/integrations/spotify/callback

# Mobile deep link — app opens this after OAuth completes in WebView
MOBILE_DEEP_LINK=kokonada://

# YouTube Music
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/integrations/youtube/callback

# Garmin
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_REDIRECT_URI=http://localhost:5000/api/integrations/garmin/callback

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Sentry
SENTRY_DSN=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
